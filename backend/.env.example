# ── Video download quality ────────────────────────────────────────────────────
# Maximum video height in pixels. Lower = smaller file, faster Gemini upload.
# 720 is the default and sufficient for transcription. Use 480 to go smaller.
VIDEO_MAX_HEIGHT=720

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Required for video transcription
GOOGLE_API_KEY=

# Gemini model name — change here to test different models
# Examples: gemini-3-flash-preview, gemini-2.5-flash-preview-05-20, gemini-2.5-pro-preview-05-06
GEMINI_MODEL=gemini-3-flash-preview

# ── LangSmith tracing ─────────────────────────────────────────────────────────
# Optional — set both to enable tracing, leave blank to disable
# Sign up free at https://smith.langchain.com (5,000 traces/month)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=creator-joy

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local Qdrant instance (start with: docker run -p 6333:6333 qdrant/qdrant:v1.17.1)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# when this env var is enabled, the pipeline does not check fo the latest verion of the models from higging face and just whaever is cahced so we save on any rate limiting hassle
HF_HUB_OFFLINE=1